---
import BaseLayout from '../layouts/BaseLayout.astro';
import { overviewGroups } from '../data/knowledge';
import { withBase } from '../consts';
---
<BaseLayout title="总览" description="工业视觉信息资料库总览">
  <section class="hero">
    <span class="kicker">Industrial Vision Reference</span>
    <h1 class="hero-title">工业视觉信息资料库</h1>
    <p class="hero-subtitle">按系统构成整理工业视觉基础信息：成像、光学、相机、接口、算法、控制输出和资料来源。内容优先参考标准组织、行业协会、官方文档和主流厂商知识库。</p>
  </section>

  <section class="section">
    <h2 class="section-title">信息模块</h2>
    <div class="grid">
      <a class="card" href={withBase('optics/')}><h3>成像与光学</h3><p>光源、镜头、视野、工作距离、景深、畸变、远心镜头。</p></a>
      <a class="card" href={withBase('cameras/')}><h3>相机与传感器</h3><p>面阵、线扫、3D 相机、智能相机、分辨率、快门、帧率、动态范围。</p></a>
      <a class="card" href={withBase('interfaces/')}><h3>接口与采集</h3><p>GenICam、GigE Vision、USB3 Vision、Camera Link、CoaXPress、采集卡。</p></a>
      <a class="card" href={withBase('models/')}><h3>算法与模型</h3><p>规则视觉、目标检测、分割、OCR、异常检测、姿态估计、3D 点云。</p></a>
      <a class="card" href={withBase('scenarios/')}><h3>场景资料</h3><p>尺寸测量、外观缺陷、OCR、机器人定位、连续材料、3D 检测。</p></a>
      <a class="card" href={withBase('sources/')}><h3>资料来源</h3><p>EMVA、A3、GenICam、EMVA 1288、Cognex、OpenCV、PaddleOCR、Anomalib。</p></a>
    </div>
  </section>

  {overviewGroups.map(group => (
    <section class="section">
      <h2 class="section-title">{group.title}</h2>
      <p class="section-lead">{group.intro}</p>
      <div class="grid">
        {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
      </div>
    </section>
  ))}
</BaseLayout>
