---
import BaseLayout from '../layouts/BaseLayout.astro';
import { overviewGroups, opticsGroups, cameraGroups, interfaceGroups, calibrationGroups, sourceGroups } from '../data/knowledge';
import { scenarios } from '../data/vision';
import { modelFamilies } from '../data/models';

const layers = [
  ['对象与现场', '工件材质、表面状态、运动方式、节拍、环境光、振动、粉尘、安装空间。'],
  ['成像与光学', '光源、镜头、视野、工作距离、景深、畸变、滤光、偏振和机械安装。'],
  ['图像采集', '相机类型、传感器、分辨率、曝光、快门、帧率、动态范围和触发方式。'],
  ['传输与同步', 'GigE Vision、USB3 Vision、Camera Link、CoaXPress、GenICam、采集卡、编码器和多相机同步。'],
  ['标定与测量', '像素比例、畸变校正、外参、手眼标定、重复性和复验条件。'],
  ['处理与算法', '预处理、定位、测量、OCR、读码、目标检测、分割、异常检测、点云和高度图处理。'],
  ['输出与集成', 'OK/NG、尺寸数值、坐标、缺陷类别、读码结果、PLC、机器人、MES、追溯和报警。'],
];
---
<BaseLayout title="总览" description="工业视觉单页信息资料库">
  <section id="overview" class="hero">
    <span class="kicker">Industrial Vision Reference</span>
    <h1 class="hero-title">工业视觉信息资料库</h1>
    <p class="hero-subtitle">按现场条件、光学成像、图像采集、数据传输、标定测量、算法处理和工业控制整理工业视觉核心资料。条目保留资料来源，便于区分标准定义、厂商资料、开源文档和工程经验。</p>
  </section>

  <section id="layers" class="section anchor-section">
    <h2 class="section-title">信息链路</h2>
    <p class="section-lead">以下顺序对应工业视觉系统的信息流：被测对象形成图像，图像被采集和传输，经过标定和算法处理后输出到控制系统或数据系统。</p>
    <div class="layer-list">
      {layers.map((layer, index) => (
        <article class="layer-item">
          <div class="layer-index">{index + 1}</div>
          <div>
            <h3>{layer[0]}</h3>
            <p>{layer[1]}</p>
          </div>
        </article>
      ))}
    </div>
  </section>

  {overviewGroups.map(group => (
    <section id="system" class="section anchor-section">
      <h2 class="section-title">{group.title}</h2>
      <p class="section-lead">{group.intro}</p>
      <div class="reference-grid">
        {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
      </div>
    </section>
  ))}

  <section id="optics" class="section anchor-section">
    <h2 class="section-title">成像与光学</h2>
    <p class="section-lead">光学部分描述图像形成条件，包括照明方向、镜头参数、视野范围、工作距离、景深、畸变和机械安装。</p>
    {opticsGroups.map(group => (
      <div class="subsection">
        <h3>{group.title}</h3>
        <p class="section-lead">{group.intro}</p>
        <div class="reference-grid">
          {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
        </div>
      </div>
    ))}
  </section>

  <section id="cameras" class="section anchor-section">
    <h2 class="section-title">相机与传感器</h2>
    <p class="section-lead">相机资料按类型和性能参数组织。分辨率、像元尺寸、快门方式、帧率、动态范围和噪声需要结合视野、速度、接口和光照条件理解。</p>
    {cameraGroups.map(group => (
      <div class="subsection">
        <h3>{group.title}</h3>
        <p class="section-lead">{group.intro}</p>
        <div class="reference-grid">
          {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
        </div>
      </div>
    ))}
  </section>

  <section id="interfaces" class="section anchor-section">
    <h2 class="section-title">接口与采集标准</h2>
    <p class="section-lead">接口层连接相机与处理设备，影响带宽、传输距离、同步方式、采集卡需求和软件兼容性。</p>
    {interfaceGroups.map(group => (
      <div class="subsection">
        <p class="section-lead">{group.intro}</p>
        <div class="reference-grid">
          {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
        </div>
      </div>
    ))}
  </section>

  <section id="calibration" class="section anchor-section">
    <h2 class="section-title">标定与测量</h2>
    <p class="section-lead">标定部分记录像素、物理尺寸、相机坐标、工件坐标和机器人坐标之间的关系。测量、定位和机器人引导场景需要独立记录标定条件和复验方法。</p>
    {calibrationGroups.map(group => (
      <div class="subsection">
        <h3>{group.title}</h3>
        <p class="section-lead">{group.intro}</p>
        <div class="reference-grid">
          {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">来源：{item.source}</p></article>)}
        </div>
      </div>
    ))}
  </section>

  <section id="algorithms" class="section anchor-section">
    <h2 class="section-title">算法与模型</h2>
    <p class="section-lead">算法部分记录从图像或点云中提取结果的方法。每个条目保留适用任务、关键参数、性能指标、数据要求、部署方式和来源。</p>
    <div class="model-list">
      {modelFamilies.map(m => (
        <article class="model-card">
          <header>
            <span class="tag">{m.category}</span>
            <h3>{m.name}</h3>
          </header>
          <div class="model-detail-grid">
            <p><strong>适用任务：</strong>{m.bestFor.join('、')}</p>
            <p><strong>常见方法：</strong>{m.typicalModels.join('、')}</p>
            <p><strong>关键参数：</strong>{m.keyParameters.join('、')}</p>
            <p><strong>性能指标：</strong>{m.performanceMetrics.join('、')}</p>
            <p><strong>数据要求：</strong>{m.dataNeed}</p>
            <p><strong>部署方式：</strong>{m.deployment.join('、')}</p>
          </div>
          <p class="source-line">来源：{m.source}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="scenarios" class="section anchor-section">
    <h2 class="section-title">典型场景</h2>
    <p class="section-lead">场景资料用于关联任务、成像、光源、相机、镜头、算法和验收指标。该部分保留摘要，不包含品牌和型号推荐。</p>
    <div class="scenario-list">
      {scenarios.map(s => (
        <article class="scenario-row">
          <div>
            <span class="tag">{s.category}</span>
            <h3>{s.title}</h3>
          </div>
          <p><strong>对象：</strong>{s.items.join('、')}</p>
          <p><strong>成像：</strong>{s.imaging}</p>
          <p><strong>光源：</strong>{s.lighting}</p>
          <p><strong>算法：</strong>{s.algorithm}</p>
          <p><strong>验收：</strong>{s.acceptance.join('、')}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="sources" class="section anchor-section">
    <h2 class="section-title">资料来源</h2>
    <p class="section-lead">标准组织和行业协会资料用于接口、相机指标和通用定义；厂商资料用于工程实现和应用说明；开源项目文档用于算法与软件生态。</p>
    {sourceGroups.map(group => (
      <div class="subsection">
        <p class="section-lead">{group.intro}</p>
        <div class="reference-grid">
          {group.items.map(item => <article class="card"><h3>{item.title}</h3><p>{item.body}</p><p class="source-line">{item.source}</p></article>)}
        </div>
      </div>
    ))}
  </section>
</BaseLayout>
