---
import BaseLayout from '../layouts/BaseLayout.astro';
import {scenarios,components,flows} from '../data/vision';
---
<BaseLayout>
<section class="hero"><h1>工业视觉选型地图</h1><p>从检测场景出发，选择成像方案、光学组件、算法路线和部署方式。</p></section>
<h2>选型流程</h2>
{flows.map(f=><div class="flow"><b>{f[0]}</b> → {f[1]}</div>)}
<h2>核心模块</h2>
<div class="grid">{components.map(c=><div class="card"><h3>{c.type}</h3><p>{c.key}</p>{c.choices.map(x=><span class="tag">{x}</span>)}</div>)}</div>
<h2>检测场景</h2>
<div class="grid">{scenarios.map(s=><div class="card"><h3>{s.title}</h3><p>{s.route}</p></div>)}</div>
</BaseLayout>
