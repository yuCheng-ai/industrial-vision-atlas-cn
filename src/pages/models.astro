---
import BaseLayout from '../layouts/BaseLayout.astro';
import { modelFamilies, modelSelectionRules } from '../data/models';
---
<BaseLayout title="模型选型" description="工业视觉模型和算法路线选型">
  <section class="hero">
    <span class="kicker">Model Selection</span>
    <h1>工业视觉模型与算法路线</h1>
    <p class="hero-subtitle">根据测量、检测、分割、OCR、异常检测、定位和 3D 任务，选择合适的算法类型、数据准备方式和部署方案。</p>
  </section>

  <section class="section">
    <h2 class="section-title">场景 → 模型路线</h2>
    <div class="matrix">
      <table>
        <thead><tr><th>场景</th><th>优先路线</th><th>工程关注点</th></tr></thead>
        <tbody>
          {modelSelectionRules.map(row => <tr><td>{row[0]}</td><td>{row[1]}</td><td>{row[2]}</td></tr>)}
        </tbody>
      </table>
    </div>
  </section>

  <section class="section">
    <h2 class="section-title">模型家族</h2>
    <div class="grid">
      {modelFamilies.map(m => (
        <article class="card">
          <span class="tag">{m.category}</span>
          <h2>{m.name}</h2>
          <p><strong>适用任务：</strong>{m.bestFor.join('、')}</p>
          <p><strong>常见模型：</strong>{m.typicalModels.join('、')}</p>
          <p><strong>使用条件：</strong>{m.useWhen.join('；')}</p>
          <p><strong>限制条件：</strong>{m.avoidWhen.join('；')}</p>
          <p><strong>数据要求：</strong>{m.dataNeed}</p>
          <p><strong>部署方式：</strong>{m.deployment.join('、')}</p>
          <p>{m.note}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
