---
import BaseLayout from '../layouts/BaseLayout.astro';
import { modelFamilies } from '../data/models';
---
<BaseLayout title="算法与模型" description="工业视觉算法与模型资料">
  <section class="hero">
    <span class="kicker">Algorithms & Models</span>
    <h1>算法与模型</h1>
    <p class="hero-subtitle">整理工业视觉常见算法类别、适用任务、数据要求和部署方式。该页面作为资料索引，不提供单一推荐结论。</p>
  </section>

  <section class="section">
    <h2 class="section-title">算法类别</h2>
    <div class="grid">
      {modelFamilies.map(m => (
        <article class="card compact-card">
          <span class="tag">{m.category}</span>
          <h2>{m.name}</h2>
          <p><strong>适用任务：</strong>{m.bestFor.join('、')}</p>
          <p><strong>常见模型 / 方法：</strong>{m.typicalModels.join('、')}</p>
          <p><strong>数据要求：</strong>{m.dataNeed}</p>
          <p><strong>部署方式：</strong>{m.deployment.join('、')}</p>
          <p class="source-line">说明：{m.note}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
