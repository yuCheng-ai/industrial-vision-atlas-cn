---
import { SITE_TITLE, withBase } from '../consts';
import '../styles/global.css';

export interface Props {
  title?: string;
  description?: string;
}
const { title, description } = Astro.props;
const pageTitle = title ? `${title} · ${SITE_TITLE}` : SITE_TITLE;
const pageDesc = description ?? '工业视觉信息资料库：成像、光学、相机、接口、算法、术语和资料来源。';
const anchor = (id: string) => `${withBase('')}#${id}`;
const navItems = [
  ['总览', anchor('overview')],
  ['系统', anchor('system')],
  ['光学', anchor('optics')],
  ['相机', anchor('cameras')],
  ['接口', anchor('interfaces')],
  ['算法', anchor('algorithms')],
  ['场景', anchor('scenarios')],
  ['来源', anchor('sources')],
];
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{pageTitle}</title>
    <meta name="description" content={pageDesc} />
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <a class="logo" href={withBase('')}>{SITE_TITLE}</a>
        <div class="nav-links">
          {navItems.map(([label, href]) => <a href={href}>{label}</a>)}
        </div>
      </nav>
      <main><slot /></main>
      <footer class="footer">© 2026 Industrial Vision Atlas CN · 工业视觉信息资料库</footer>
    </div>
  </body>
</html>
